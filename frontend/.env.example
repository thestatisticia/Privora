# Soroban contract address (testnet)
NEXT_PUBLIC_CONTRACT_ID=

# Network: "testnet" or "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# Soroban RPC endpoint
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Default Merkle root (decimal, from voter snapshot)
NEXT_PUBLIC_MERKLE_ROOT=

# Relayer keypair (TESTNET DEMO ONLY — move to a backend for production)
NEXT_PUBLIC_RELAYER_SECRET=
NEXT_PUBLIC_RELAYER_PUBLIC=

# Admin wallet — only this address can access /review
NEXT_PUBLIC_ADMIN_WALLET=
